  "@type": "sc:Dataset",
  "name": "Synthea FHIR R4 Sample",
  "description": "Synthetic patient data generated by Synthea in FHIR R4 format. Includes Patient, Observation, Condition, MedicationRequest, DiagnosticReport, and other clinical resource types.",
  "version": "1.0.0",
  "license": "https://www.apache.org/licenses/LICENSE-2.0",
  "url": "https://synthetichealth.github.io/synthea/",
  "datePublished": "2025-01-01",
  "creator": [
    {
      "@type": "Person",
      "name": "Synthea (MITRE)"
    },
    {
      "@type": "Organization",
      "name": "Florida Institute of Technology"
    }
  ],
  "keywords": [
    "FHIR",
    "R4",
    "synthetic",
    "clinical",
    "healthcare",
    "EHR",
    "medical",
    "patient"
  ],
  "publisher": {
    "@type": "Organization",
    "name": "jsonld-ex project"
  },
  "dateCreated": "2025-01-01",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "fhir_bundles.ndjson",
      "name": "fhir_bundles.ndjson",
      "contentUrl": "local://data/synthea/fhir_r4/",
      "encodingFormat": "application/fhir+json",
      "description": "FHIR R4 Bundle resources in NDJSON format"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "@id": "patients",
      "name": "patients",
      "field": [
        {
          "@type": "cr:Field",
          "name": "patient_id",
          "dataType": "sc:Text",
          "description": "FHIR Patient resource ID",
          "@id": "patients/patient_id"
        },
        {
          "@type": "cr:Field",
          "name": "gender",
          "dataType": "sc:Text",
          "description": "Administrative gender",
          "@id": "patients/gender"
        },
        {
          "@type": "cr:Field",
          "name": "birth_date",
          "dataType": "sc:Date",
          "description": "Date of birth",
          "@id": "patients/birth_date"
        }
      ],
      "description": "Patient demographic records"
    },
    {
      "@type": "cr:RecordSet",
      "@id": "observations",
      "name": "observations",
      "field": [
        {
          "@type": "cr:Field",
          "name": "observation_id",
          "dataType": "sc:Text",
          "description": "FHIR Observation resource ID",
          "@id": "observations/observation_id"
        },
        {
          "@type": "cr:Field",
          "name": "code",
          "dataType": "sc:Text",
          "description": "LOINC observation code",
          "@id": "observations/code"
        },
        {
          "@type": "cr:Field",
          "name": "value",
          "dataType": "sc:Float",
          "description": "Numeric observation value",
          "@id": "observations/value"
        },
        {
          "@type": "cr:Field",
          "name": "unit",
          "dataType": "sc:Text",
          "description": "Unit of measurement",
          "@id": "observations/unit"
        }
      ],
      "description": "Clinical observation records"
    }
  ],
  "conformsTo": "http://mlcommons.org/croissant/1.0"
}